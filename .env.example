# LLM（DeepSeek / 其他 OpenAI 兼容服务）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# 可选：远程 Embedding API。留空时使用 Chroma 的本地 Embedding 模型。
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# PDF / RAG
MAX_UPLOAD_SIZE_MB=20
PDF_CHUNK_SIZE=800
PDF_CHUNK_OVERLAP=120
RAG_TOP_K=4
RAG_CANDIDATE_K=24

# 扫描版 PDF OCR：安装 Tesseract 后才设为 true。
PDF_ENABLE_OCR=false
TESSERACT_CMD=

# 会话记忆
SESSION_HISTORY_LIMIT=12

APP_ENV=development
DEBUG=true
